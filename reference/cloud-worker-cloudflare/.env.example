# Open MDB ingestor — local development secrets.
# Copy to .dev.vars for `wrangler dev`. Production secrets are set via
# `wrangler secret put <NAME>` and never live in any committed file.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs.YOUR_SERVICE_ROLE_KEY_HERE

# Shared bearer token. The Pi listener sends this in Authorization headers;
# the Worker rejects anything else with 401. Generate something long:
#   openssl rand -hex 32
INGEST_SECRET=replace-with-a-long-random-string
