# Open MDB dashboard — Supabase configuration.
# Copy to .env.local and fill in values from your Supabase project's Settings → API.
# Both values are safe to expose in client bundles — the anon key only has read access
# (and optionally write access to slots if you applied 004_dashboard_writes.sql).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs.YOUR_ANON_KEY_HERE
