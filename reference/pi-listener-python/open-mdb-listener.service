[Unit]
Description=Open MDB MDB vend listener
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=open-mdb
WorkingDirectory=/home/open-mdb/open-mdb/reference/pi-listener-python
EnvironmentFile=/home/open-mdb/open-mdb/reference/pi-listener-python/.env
ExecStart=/home/open-mdb/open-mdb/reference/pi-listener-python/.venv/bin/python main.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
