# OpenVend Pi listener — example environment.
# Copy to .env and fill in real values. Do NOT commit .env.

MACHINE_ID=MACHINE-001
SERIAL_DEVICE=/dev/ttyAMA0

# OpenVend cloud ingestor — your deployed Cloudflare Worker.
# After `wrangler deploy`, this looks like:
#   https://openvend-ingestor.<your-account>.workers.dev/vends
INGEST_URL=https://openvend-ingestor.example.workers.dev/vends

# Shared bearer token. Must match the INGEST_SECRET set on the Worker.
# Generate with: openssl rand -hex 32
INGEST_SECRET=replace-with-a-long-random-string
