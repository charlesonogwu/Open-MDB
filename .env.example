# Open MDB — root-level environment example.
# Subprojects under reference/* have their own .env.example with project-specific vars.

# Supabase project (for cloud worker + dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs.YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs.YOUR_SERVICE_ROLE_KEY_HERE

# Shared secret between the Pi listener and the cloud ingestor.
# Generate with: openssl rand -hex 32
INGEST_SECRET=replace-with-a-long-random-string

# Subproject-specific examples:
# - reference/pi-listener-python/.env.example
# - reference/cloud-worker-cloudflare/.env.example
